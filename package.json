{
  "name": "notion2council-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell and launcher menu for Notion2LLMcouncil Plus.",
  "author": "Sanity Cloud",
  "main": "electron/main.js",
  "scripts": {
    "setup": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-desktop.ps1",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "start": "npm run electron:dev",
    "electron:build": "npm run electron:build:exe && npm run electron:build:zip && npm run electron:build:msi",
    "electron:build:exe": "electron-builder --config electron-builder.portable.json --win portable --publish never",
    "electron:build:zip": "electron-builder --config electron-builder.portable.json --win zip --config.artifactName=Notion2Council-0.1.0-win-x64.zip --publish never",
    "electron:build:msi": "electron-builder --win msi --publish never",
    "electron:pack": "electron-builder --dir",
    "release:local": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/package-release.ps1",
    "release:dir": "npm run electron:pack"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "cloud.sanity.notion2council",
    "productName": "Notion2Council",
    "directories": { "output": "release" },
    "files": ["electron/**/*", "scripts/**/*", "config/default.json", "config/prompt-presets.json", "launch.bat", "stop.bat", "setup.bat", "setup-desktop.bat", "package-release.bat", "launch-ui.bat", "build-ui-exe.bat", "build-setup-msi.bat", "README.md"],
    "extraMetadata": { "main": "electron/main.js" },
    "win": { "icon": "electron/icon.ico" },
    "portable": { "artifactName": "Notion2Council-0.1.0-portable.exe" },
    "msi": { "artifactName": "Notion2Council-0.1.0-setup.msi", "upgradeCode": "AD379612-CB12-4220-A03D-76A8A3C98E51" }
  }
}
