{
  "appId": "cloud.sanity.notion2council",
  "productName": "Notion2Council",
  "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
  "directories": {
    "output": "release"
  },
  "files": [
    "electron/**/*",
    "scripts/**/*",
    "config/default.json",
    "config/prompt-presets.json",
    "launch.bat",
    "stop.bat",
    "setup.bat",
    "setup-desktop.bat",
    "package-release.bat",
    "launch-ui.bat",
    "build-ui-exe.bat",
    "build-setup-msi.bat",
    "README.md"
  ],
  "extraMetadata": {
    "main": "electron/main.js"
  },
  "portable": {
    "artifactName": "Notion2Council-${version}-portable.${ext}"
  },
  "nsis": {
    "artifactName": "Notion2Council-${version}-setup.${ext}",
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Notion2Council"
  }
}
