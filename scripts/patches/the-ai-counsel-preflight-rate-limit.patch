+
+# Maximum number of retry attempts for transient rate-limit errors.
+PREFLIGHT_RATE_LIMIT_RETRIES = 2
+# Base backoff delay (seconds) between retries; doubles each attempt.
+PREFLIGHT_RATE_LIMIT_BACKOFF = 1.5
+# Hard ceiling on total wall-clock time spent on a single model's preflight
+# (including all retry sleeps).  Prevents sustained congestion from hanging
+# the entire preflight pass.
+PREFLIGHT_MAX_WALL_SECONDS = 12.0
+
+
+def _is_transient_rate_limit(status_code: int, message: str) -> bool:
+    """Classify an error as a transient rate-limit.
+
+    Match priority (most stable ΓåÆ least stable):
+      1. HTTP status code 429 via the shared provider helper
+      2. Structured error markers in the response body via the provider helper
+      3. Substring match in the error message string as last-resort fallback
+
+    This mirrors ``_is_rate_limited`` in custom_openai.py but operates on
+    the error *string* surfaced by ``query_model`` rather than a raw HTTP
+    response, since model_preflight only sees the abstracted result dict.
+    """
+    # Delegate to provider helper when a status code is available
+    if status_code:
+        return _provider_is_rate_limited(status_code, message)
+
+    # Fallback: match on error message text only
+    text = (message or "").lower()
+    return any(
+        m in text
+        for m in (
+            "notion rate limit",
+            "rate limit",
+            "rate_limit",
+            "429",
+            "too many requests",
+            "quota",
+            "throttl",
+        )
+    )
+
+
+def _extract_status_code(result: dict | None) -> int:
+    """Pull an HTTP status code out of a query_model result dict if available."""
+    if not result:
+        return 0
+    # custom_openai embeds timeline entries with 'status'
+    timeline = result.get("debug_timeline") or []
+    if timeline:
+        return int(timeline[-1].get("status") or 0)
+    return 0
+
 
