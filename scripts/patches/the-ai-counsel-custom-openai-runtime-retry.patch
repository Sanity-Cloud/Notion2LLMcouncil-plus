+    def _supports_attachments(self, name: str, base_url: str) -> bool:
+        """Attachments are only sent to Notion2API-compatible custom endpoints."""
+        marker = f"{name} {base_url}".lower()
+        return "notion" in marker or "127.0.0.1:8000" in marker or "localhost:8000" in marker
+
+    def _attachment_retry_config(self) -> tuple[int, float]:
+        settings = get_settings()
+        try:
+            if hasattr(settings, "attachment_max_attempts"):
+                attempts = max(1, int(settings.attachment_max_attempts))
+            else:
+                attempts = max(1, int(os.getenv("LLM_COUNCIL_ATTACHMENT_MAX_ATTEMPTS", "3")))
+        except (TypeError, ValueError):
+            attempts = 3
+        try:
+            if hasattr(settings, "attachment_retry_delay_seconds"):
+                delay = max(0.0, float(settings.attachment_retry_delay_seconds))
+            else:
+                delay = max(0.0, float(os.getenv("LLM_COUNCIL_ATTACHMENT_RETRY_DELAY_SECONDS", "35")))
+        except (TypeError, ValueError):
+            delay = 35.0
+        return attempts, delay
+
     def _is_attachment_rate_limit(self, status_code: int, response_text: str) -> bool:
         """Legacy attachment-specific rate-limit check (delegates to shared helper)."""
