+    const suffix = formatVersionSuffix(rawName.replace(/^deepseek-/i, '').replace(/-/g, ' '));
+    return `DeepSeek ${titleCaseWords(suffix)}`;
+  }
+
+  return titleCaseWords(formatVersionSuffix(rawName.replace(/[-_]+/g, ' ')));
 };
