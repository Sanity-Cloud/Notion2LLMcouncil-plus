+def _attachment_delay_seconds() -> float:
+    """Delay between attachment-bearing Notion2API calls to avoid file-import 429s."""
+    raw = os.getenv("LLM_COUNCIL_ATTACHMENT_DELAY_SECONDS", "12")
+    try:
+        return max(0.0, float(raw))
+    except (TypeError, ValueError):
+        return 12.0
+
+
+async def _maybe_pause_after_attachment_call() -> None:
+    delay = _attachment_delay_seconds()
+    if delay > 0:
+        await asyncio.sleep(delay)
