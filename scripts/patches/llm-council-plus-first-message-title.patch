+DEFAULT_CONVERSATION_TITLES = {None, "", "New Conversation", "Untitled Conversation"}
+
+
+def _is_default_conversation_title(title: Optional[str]) -> bool:
+    return title in DEFAULT_CONVERSATION_TITLES
+
+
+def _derive_conversation_title(content: str) -> str:
+    """Create a stable fallback title from the first user message."""
+    if not content or not isinstance(content, str):
+        return "Untitled Conversation"
+
+    title = " ".join(content.strip().split())
+    if not title:
+        return "Untitled Conversation"
+
+    title = title.strip("\"'")
+
+    if len(title) > 50:
+        title = title[:47] + "..."
+
+    return title
+
+
+def _first_user_message_content(conversation: Dict[str, Any]) -> str:
+    for msg in conversation.get("messages", []):
+        if msg.get("role") == "user" and msg.get("content"):
+            return msg.get("content", "")
+    return ""
+
+
+def _ensure_conversation_title(conversation: Dict[str, Any]) -> bool:
+    """Backfill default conversation titles from the first user message."""
+    if not _is_default_conversation_title(conversation.get("title")):
+        return False
+
+    first_user_message = _first_user_message_content(conversation)
+    if not first_user_message:
+        return False
+
+    conversation["title"] = _derive_conversation_title(first_user_message)
+    return True
+
