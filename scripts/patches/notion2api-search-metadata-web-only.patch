+def _message_content_to_text(content: Any) -> str:
+    """Flatten OpenAI string or multipart message content to plain text."""
+    if content is None:
         return ""
+    if isinstance(content, str):
+        return content
+    if isinstance(content, list):
+        parts: list[str] = []
+        for item in content:
+            if isinstance(item, str):
+                if item:
+                    parts.append(item)
+                continue
+            if not isinstance(item, dict):
+                continue
+            item_type = str(item.get("type") or "").lower()
+            if item_type in {"input_text", "output_text", "text"} or "text" in item:
+                text = str(item.get("text") or "")
+                if text:
+                    parts.append(text)
+        return "\n".join(parts)
+    return str(content)
+
+
+def _last_user_message_content(messages: Iterable[Any]) -> Any:
+    """Return the content field from the last user message, if any."""
+    for message in reversed(list(messages)):
+        role = getattr(message, "role", None)
+        if role is None and isinstance(message, dict):
+            role = message.get("role")
+        if role != "user":
+            continue
+        content = getattr(message, "content", None)
+        if content is None and isinstance(message, dict):
+            content = message.get("content")
+        return content
+    return ""
+
