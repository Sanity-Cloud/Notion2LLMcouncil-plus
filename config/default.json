{
  "notion": {
    "localRoot": "vendor\\notion2api",
    "repoUrl": "https://github.com/Sanity-Cloud/notion2api.git",
    "branch": "main",
    "port": 8000,
    "appMode": "standard",
    "autoLogin": true,
    "loginTimeoutSeconds": 300,
    "persistThreads": false,
    "generateTitles": false,
    "saveThreadOperations": false,
    "setUnreadState": false,
    "deleteEphemeralThreads": true
  },
  "council": {
    "localRoot": "vendor\\the-ai-counsel",
    "repoUrl": "https://github.com/Sanity-Cloud/the-ai-counsel.git",
    "branch": "main",
    "backendPort": 8001,
    "frontendPort": 5173,
    "settingsMode": "auto",
    "verifyProvider": true,
    "askSmokeTest": true,
    "clearUiStorageOnProviderDrift": false
  },
  "provider": {
    "name": "Notion2API",
    "enabledKey": "custom",
    "urlPath": "/v1",
    "supportsStreaming": true,
    "autoRepair": true,
    "applyDefaultCouncil": false,
    "councilModels": [
      "custom:gpt-5.5",
      "custom:claude-opus4.7",
      "custom:claude-opus4.8",
      "custom:gemini-3.1pro",
      "custom:kimi-2.6",
      "custom:deepseek-v4pro",
      "custom:claude-sonnet4.6",
      "custom:claude-opus4.6",
      "custom:gpt-5.2",
      "custom:gpt-5.4",
      "custom:gpt-5.4mini",
      "custom:gpt-5.4nano",
      "custom:gemini-3flash",
      "custom:gemini-3.5flash",
      "custom:gemini-2.5flash"
    ],
    "chairmanModel": "custom:claude-opus4.7",
    "councilMemberFilters": {
      "0": "remote",
      "1": "remote",
      "2": "remote",
      "3": "remote"
    },
    "chairmanFilter": "remote",
    "searchQueryFilter": "remote"
  },
  "sigmap": {
    "scriptPath": ""
  }
}
